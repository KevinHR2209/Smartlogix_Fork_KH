# Copiar este archivo a .env (en la raiz del repo, junto a docker-compose.yml)
# y completar con tus credenciales de PRUEBA de Mercado Pago.
# NUNCA commitear el archivo .env real (ya esta en .gitignore).
#
# Paso a paso para obtener estas credenciales: ver ms-ventas/README-MERCADOPAGO.md

# Access token de PRUEBA (empieza con "TEST-"). Se obtiene en:
# https://www.mercadopago.cl/developers/panel/app -> Credenciales de prueba
MERCADOPAGO_ACCESS_TOKEN=APP_USR-6369945253134743-071219-f8aa9e27a255c5154d4a79f94e00261c-3535802609

# A donde Mercado Pago redirige al comprador de prueba despues de pagar.
# Para pruebas sin frontend conectado, se puede dejar asi tal cual.
MERCADOPAGO_BACK_URL_SUCCESS=http://localhost:3000/pago/exito
MERCADOPAGO_BACK_URL_FAILURE=http://localhost:3000/pago/error
MERCADOPAGO_BACK_URL_PENDING=http://localhost:3000/pago/pendiente

# URL publica donde Mercado Pago envia el webhook cuando cambia el estado
# de un pago. En local no es alcanzable desde internet, hay que exponerla
# con ngrok (o similar) para probar el webhook real. Ver README-MERCADOPAGO.md.
# Ejemplo: https://a1b2c3d4.ngrok-free.app/api/pagos/mercadopago/webhook
MERCADOPAGO_NOTIFICATION_URL=
NEXT_PUBLIC_ML_FORECAST_URL=http://localhost:8004